{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/api/sessions": {
            "post": {
                "description": "Запускает новую «исповедальную» сессию с начальным значением счётчика (tally) 50.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sessions"
                ],
                "summary": "Создать новую чат-сессию",
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/entity.CreateSessionResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/sessions/{id}": {
            "get": {
                "description": "Возвращает текущий статус, значение счётчика и финальный результат (если сессия завершена).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sessions"
                ],
                "summary": "Получить состояние сессии",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID сессии",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/entity.GetSessionResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/sessions/{id}/messages": {
            "get": {
                "description": "Возвращает хронологическую историю сообщений (первые 200).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "messages"
                ],
                "summary": "Получить сообщения сессии",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID сессии",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/entity.ListMessagesResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Принимает текст пользователя, отправляет его в LLM, возвращает JSON-ответ ассистента и обновляет счётчик (tally).",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "messages"
                ],
                "summary": "Отправить сообщение пользователя в сессию",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID сессии",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Сообщение пользователя",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/entity.PostMessageRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/entity.PostMessageResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "entity.BotPayload": {
            "type": "object",
            "properties": {
                "next_step": {
                    "description": "Рекомендованное следующее действие",
                    "type": "string"
                },
                "repentance": {
                    "description": "Детализация оценки «покаяния»",
                    "allOf": [
                        {
                            "$ref": "#/definitions/entity.Repentance"
                        }
                    ]
                },
                "reply": {
                    "description": "Текстовый ответ ассистента для пользователя",
                    "type": "string"
                },
                "risk_flag": {
                    "description": "Флаг риска: при true tally не меняется",
                    "type": "boolean"
                }
            }
        },
        "entity.CreateSessionResponse": {
            "type": "object",
            "properties": {
                "id": {
                    "description": "ID созданной сессии",
                    "type": "string"
                },
                "status": {
                    "description": "Статус сессии",
                    "type": "string"
                },
                "tally": {
                    "description": "Начальное значение счётчика",
                    "type": "integer"
                }
            }
        },
        "entity.GetSessionResponse": {
            "type": "object",
            "properties": {
                "id": {
                    "description": "ID сессии",
                    "type": "string"
                },
                "outcome": {
                    "description": "Итог (если сессия закрыта)",
                    "type": "string"
                },
                "status": {
                    "description": "Текущий статус",
                    "type": "string"
                },
                "tally": {
                    "description": "Текущее значение счётчика",
                    "type": "integer"
                }
            }
        },
        "entity.ListMessagesResponse": {
            "type": "object",
            "properties": {
                "items": {
                    "description": "Сообщения в хронологическом порядке",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/entity.MessageDTO"
                    }
                },
                "session_id": {
                    "description": "ID сессии",
                    "type": "string"
                }
            }
        },
        "entity.MessageDTO": {
            "type": "object",
            "properties": {
                "content": {
                    "description": "Содержимое (для ассистента — JSON-строка)",
                    "type": "string"
                },
                "created_at": {
                    "description": "Время создания в формате RFC3339",
                    "type": "string"
                },
                "id": {
                    "description": "ID сообщения",
                    "type": "string"
                },
                "role": {
                    "description": "Роль автора (user/assistant)",
                    "type": "string"
                }
            }
        },
        "entity.PostMessageRequest": {
            "type": "object",
            "properties": {
                "text": {
                    "description": "Текст пользователя",
                    "type": "string"
                }
            }
        },
        "entity.PostMessageResponse": {
            "type": "object",
            "properties": {
                "assistant": {
                    "description": "Пейлоад ассистента (JSON)",
                    "allOf": [
                        {
                            "$ref": "#/definitions/entity.BotPayload"
                        }
                    ]
                },
                "done": {
                    "description": "Признак завершения сессии",
                    "type": "boolean"
                },
                "outcome": {
                    "description": "Итог («вы прощены»/«вы не прощены»), если Done=true",
                    "type": "string"
                },
                "tally": {
                    "description": "Текущее значение счётчика после обработки",
                    "type": "integer"
                }
            }
        },
        "entity.Repentance": {
            "type": "object",
            "properties": {
                "confidence": {
                    "description": "Уверенность модели (низкая/средняя/высокая и т.п.)",
                    "type": "string"
                },
                "score": {
                    "description": "Итоговый балл (0..100), может отсутствовать при RiskFlag",
                    "type": "integer"
                },
                "signals": {
                    "description": "Перечень факторов",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/entity.Signal"
                    }
                },
                "trend": {
                    "description": "Тренд изменения (например, improving/declining/stable)",
                    "type": "string"
                }
            }
        },
        "entity.Signal": {
            "type": "object",
            "properties": {
                "direction": {
                    "description": "Направление влияния (например, up/down/neutral)",
                    "type": "string"
                },
                "evidence": {
                    "description": "Краткое обоснование/доказательство",
                    "type": "string"
                },
                "factor": {
                    "description": "Название фактора",
                    "type": "string"
                }
            }
        }
    }
}